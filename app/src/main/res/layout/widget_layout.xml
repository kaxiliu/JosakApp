<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000"
    android:padding="12dp">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="JOSAKAPP"
        android:textColor="#7BB7F5"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_title"
        android:layout_marginTop="8dp"
        android:text="¿Hiciste tus hábitos?"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

    <LinearLayout
        android:id="@+id/widget_habito_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_below="@id/widget_status_text"
        android:layout_marginTop="12dp"
        android:background="#33FFFFFF"
        android:padding="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_habito_nombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cargando..."
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_widget_cumplir"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Cumplir"
            android:textSize="10sp"
            android:backgroundTint="#7BB7F5" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:text="Toca la notificación para marcar"
        android:textColor="#B0FFFFFF"
        android:textSize="10sp" />
</RelativeLayout>